# WaffleStack — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# .env.local is git-ignored.

# Tripo AI — text-to-3D model generation (used by `npm run tripo:generate`).
# Get an API key at https://platform.tripo3d.ai (≈600 free credits/month).
TRIPO_API_KEY=your-tripo-api-key-here

# Optional: override the API base if Tripo changes the endpoint
# TRIPO_API_BASE=https://api.tripo3d.ai/v2/openapi

# Browser-exposed alternative (read via import.meta.env.VITE_TRIPO_API_KEY).
# Only set if you want a runtime client-side helper to call Tripo from the app.
VITE_TRIPO_API_KEY=

# ImagineArt API Key — Get a key at https://docs.imagine.art
VITE_IMAGINE_API_KEY=your-imagine-api-key-here

# OpenAI API Key — used by the AI Study Tutor edge function (api/tutor/chat.ts).
# Server-side only; NOT exposed to the browser. Get one at https://platform.openai.com.
# Model: gpt-4o-mini (cheap, fast, sufficient for Hebrew Socratic tutoring).
OPENAI_API_KEY=

# tldraw license key — used by the OneNote-style notebook (src/components/notebook).
# tldraw v5 commercial; without a key, canvas is blocked in production.
# Get a FREE hobby license at https://tldraw.dev/get-a-license/hobby (5-min signup).
# Copy resulting key here (browser-exposed via VITE_ prefix).
VITE_TLDRAW_LICENSE_KEY=

