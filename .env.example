# Base44 Environment Variables
# Copy this file to .env and fill in your API keys

# TripoAI API Key
# Get your API key from: https://platform.tripo3d.ai
VITE_TRIPO_API_KEY=your-tripo-api-key-here

# ImagineArt API Key
# Get your API key from: https://docs.imagine.art
VITE_IMAGINE_API_KEY=your-imagine-api-key-here
